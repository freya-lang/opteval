{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build",
			"type": "shell",
			"command": "cargo build --release",
			"group": {
				"kind": "build",
				"isDefault": true,
			},
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "new",
				"showReuseMessage": true,
				"clear": false,
				"close": true,
			},
		},
		{
			"label": "run tests",
			"type": "shell",
			"command": "cargo test",
			"group": {
				"kind": "test",
				"isDefault": true,
			},
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "new",
				"showReuseMessage": true,
				"clear": false,
				"close": true,
			},
		},
		{
			"label": "run fmt",
			"type": "shell",
			"command": "cargo fmt",
			"presentation": {
				"echo": true,
				"reveal": "silent",
				"focus": false,
				"panel": "new",
				"showReuseMessage": true,
				"clear": false,
				"close": true,
			},
		},
	],
}
